document.addEventListener('keydown', e => { if (e.key === 'Escape') closeM(); });

// ── FORM FUNCTIONS ──
let selectedRating = 0;
let selectedFreq = 'daily';

function setRating(val) {
  selectedRating = val;
  // Write value into the hidden input so Formspree receives it
  document.getElementById('rating-hidden').value = val;
  document.querySelectorAll('.rating-btn').forEach(btn => {
    btn.classList.toggle('selected', parseInt(btn.dataset.val) === val);
  });
  document.getElementById('rating-error').style.display = 'none';
}

function toggleCheck(label) {
  const cb = label.querySelector('input[type="checkbox"]');
  setTimeout(() => { label.classList.toggle('checked', cb.checked); }, 0);
}

function handleSubscribeToggle(checkbox) {
  const card       = document.getElementById('subscribe-card');
  const emailWrap  = document.getElementById('subscribe-email-wrap');
  const freqWrap   = document.getElementById('subscribe-freq-wrap');
  const submitBtn  = document.getElementById('submit-btn');
  const submitNote = document.getElementById('submit-note');
  if (checkbox.checked) {
    card.classList.add('active');
    emailWrap.style.display = 'block';
    freqWrap.style.display  = 'block';
    submitBtn.textContent   = 'Send feedback & subscribe →';
    submitNote.textContent  = "You'll receive The Brief at the address above.";
  } else {
    card.classList.remove('active');
    emailWrap.style.display = 'none';
    freqWrap.style.display  = 'none';
    document.getElementById('subscribe-email-error').style.display = 'none';
    submitBtn.textContent   = 'Send feedback →';
    submitNote.textContent  = 'Your response stays private.';
  }
}

function setFreq(label, val) {
  selectedFreq = val;
  document.querySelectorAll('.freq-btn').forEach(b => b.classList.remove('active'));
  label.classList.add('active');
}

function submitForm(e) {
  e.preventDefault();

  // Validate rating
  if (!selectedRating) {
    document.getElementById('rating-error').style.display = 'block';
    document.getElementById('rating-row').scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }

  // Validate subscribe email if toggled on
  const isSubscribed     = document.getElementById('subscribe-toggle').checked;
  const subscribeEmailEl = document.getElementById('subscribe-email');
  const readerEmail      = document.getElementById('reader-email').value.trim();
  if (isSubscribed) {
    const subEmail = subscribeEmailEl ? subscribeEmailEl.value.trim() : '';
    if (!subEmail && !readerEmail) {
      document.getElementById('subscribe-email-error').style.display = 'block';
      subscribeEmailEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      subscribeEmailEl.focus();
      return;
    }
    document.getElementById('subscribe-email-error').style.display = 'none';
  }

  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending…';
  btn.disabled    = true;

  const form = document.getElementById('feedback-form');
  const formData = new FormData(form);

  // Submit to Formspree via AJAX so we can show our own success screen
  fetch(form.action, {
    method: 'POST',
    body: formData,
    headers: { 'Accept': 'application/json' }
  })
  .then(res => {
    if (res.ok) {
      showSuccess();
    } else {
      res.json().then(data => {
        btn.textContent = 'Send feedback →';
        btn.disabled    = false;
        alert('Something went wrong: ' + (data.errors ? data.errors.map(e => e.message).join(', ') : 'please try again.'));
      });
    }
  })
  .catch(() => {
    btn.textContent = 'Send feedback →';
    btn.disabled    = false;
    alert('Network error — please check your connection and try again.');
  });
}

function showSuccess() {
  document.getElementById('feedback-form').style.display = 'none';
  const successEl = document.getElementById('form-success');
  successEl.style.display = 'block';
  successEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Mark first freq button active on load
window.addEventListener('load', () => {
  const first = document.querySelector('.freq-btn');
  if (first) first.classList.add('active');
});
</script>

