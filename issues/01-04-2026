function openM(id) {
  const a = M[id]; if (!a) return;
  document.getElementById('mtag').textContent  = a.tag;
  document.getElementById('mhl').textContent   = a.hl;
  document.getElementById('mbody').innerHTML   = a.body;
  document.getElementById('msrc-label').textContent = a.src;
  document.getElementById('msrc-link').href    = a.url;
  document.getElementById('mbg').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeM() {
  document.getElementById('mbg').classList.remove('open');
  document.body.style.overflow = '';
}
function outsideClose(e) {
  if (e.target === document.getElementById('mbg')) closeM();
}
function go(id, btn) {
  document.querySelectorAll('.sec').forEach(s => s.classList.remove('on'));
  document.querySelectorAll('.ntab').forEach(b => b.classList.remove('on'));
  document.getElementById('sec-' + id).classList.add('on');
  btn.classList.add('on');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeM(); });

// ── FORM FUNCTIONS ──
let selectedRating = 0;
let selectedFreq = 'daily';

function setRating(val) {
  selectedRating = val;
  // Write value into the hidden input so Formspree receives it
  document.getElementById('rating-hidden').value = val;
  document.querySelectorAll('.rating-btn').forEach(btn => {
    btn.classList.toggle('selected', parseInt(btn.dataset.val) === val);
  });
  document.getElementById('rating-error').style.display = 'none';
}

function toggleCheck(label) {
  const cb = label.querySelector('input[type="checkbox"]');
  setTimeout(() => { label.classList.toggle('checked', cb.checked); }, 0);
}

function handleSubscribeToggle(checkbox) {
  const card       = document.getElementById('subscribe-card');
  const emailWrap  = document.getElementById('subscribe-email-wrap');
  const freqWrap   = document.getElementById('subscribe-freq-wrap');
  const submitBtn  = document.getElementById('submit-btn');
  const submitNote = document.getElementById('submit-note');
  const emailNote  = document.getElementById('email-required-note');
  if (checkbox.checked) {
    card.classList.add('active');
    emailWrap.style.display = 'block';
    freqWrap.style.display  = 'block';
    submitBtn.textContent   = 'Send feedback & subscribe →';
    submitNote.textContent  = "You'll receive The Brief at the address above.";
    if (emailNote) emailNote.innerHTML = '(required for newsletter) <span style="color:var(--red)">*</span>';
  } else {
    card.classList.remove('active');
    emailWrap.style.display = 'none';
    freqWrap.style.display  = 'none';
    document.getElementById('subscribe-email-error').style.display = 'none';
    submitBtn.textContent   = 'Send feedback →';
    submitNote.textContent  = 'Your response stays private.';
    if (emailNote) emailNote.textContent = '(for a reply)';
  }
}

function toggleWhatsApp() {
  setTimeout(() => {
    const cb    = document.getElementById('whatsapp-checkbox');
    const wrap  = document.getElementById('whatsapp-mobile-wrap');
    const input = document.getElementById('whatsapp-mobile');
    if (cb && cb.checked) {
      wrap.style.display = 'block';
      input.focus();
    } else {
      wrap.style.display = 'none';
      document.getElementById('whatsapp-mobile-error').style.display = 'none';
    }
  }, 0);
}

function setFreq(label, val) {
  selectedFreq = val;
  document.querySelectorAll('.freq-btn').forEach(b => b.classList.remove('active'));
  label.classList.add('active');
}

function submitForm(e) {
  e.preventDefault();

  // ── 1. Rating required ───────────────────────────────────────
  if (!selectedRating) {
    document.getElementById('rating-error').style.display = 'block';
    document.getElementById('rating-row').scrollIntoView({ behavior: 'smooth', block: 'center' });
    return;
  }
  document.getElementById('rating-error').style.display = 'none';

  // ── 2. Gather contact fields ─────────────────────────────────
  const isSubscribed     = document.getElementById('subscribe-toggle').checked;
  const subscribeEmailEl = document.getElementById('subscribe-email');
  const readerEmailEl    = document.getElementById('reader-email');
  const whatsappCb       = document.getElementById('whatsapp-checkbox');
  const whatsappMobile   = document.getElementById('whatsapp-mobile');

  const subEmail    = (subscribeEmailEl  ? subscribeEmailEl.value.trim()  : '');
  const readerEmail = (readerEmailEl     ? readerEmailEl.value.trim()     : '');
  const mobile      = (whatsappMobile    ? whatsappMobile.value.trim()    : '');
  const wantWA      = whatsappCb && whatsappCb.checked;

  // ── 3. Subscribe on → email required ────────────────────────
  if (isSubscribed && !subEmail && !readerEmail) {
    document.getElementById('subscribe-email-error').style.display = 'block';
    subscribeEmailEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    subscribeEmailEl.focus();
    return;
  }
  document.getElementById('subscribe-email-error').style.display = 'none';

  // ── 4. WhatsApp ticked → mobile required ────────────────────
  if (wantWA && !mobile) {
    document.getElementById('whatsapp-mobile-error').style.display = 'block';
    whatsappMobile.scrollIntoView({ behavior: 'smooth', block: 'center' });
    whatsappMobile.focus();
    return;
  }
  if (whatsappMobile) document.getElementById('whatsapp-mobile-error').style.display = 'none';

  // ── 5. Always require at least one contact detail ────────────
  // User must provide at minimum an email or a mobile number
  const hasEmail  = !!(subEmail || readerEmail);
  const hasMobile = !!mobile;
  if (!hasEmail && !hasMobile) {
    // Show error on the reader-email field since it's the most visible
    const errId = 'contact-required-error';
    let errEl = document.getElementById(errId);
    if (!errEl) {
      errEl = document.createElement('div');
      errEl.id = errId;
      errEl.style.cssText = 'color:var(--red);font-size:13px;margin-top:0.5rem;padding:0.7rem 1rem;background:#fdf2f2;border-radius:6px;border:1px solid #f0c0c0';
      errEl.textContent = 'Please provide at least an email address or mobile number so we can follow up.';
      readerEmailEl.parentNode.insertBefore(errEl, readerEmailEl.nextSibling);
    }
    errEl.style.display = 'block';
    readerEmailEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    readerEmailEl.focus();
    return;
  }
  // Hide contact error if it exists
  const existingErr = document.getElementById('contact-required-error');
  if (existingErr) existingErr.style.display = 'none';

  const btn = document.getElementById('submit-btn');
  btn.textContent = 'Sending…';
  btn.disabled    = true;

  const form = document.getElementById('feedback-form');
  const formData = new FormData(form);

  // Submit to Formspree via AJAX so we can show our own success screen
  fetch(form.action, {
    method: 'POST',
    body: formData,
    headers: { 'Accept': 'application/json' }
  })
  .then(res => {
    if (res.ok) {
      showSuccess();
    } else {
      res.json().then(data => {
        btn.textContent = 'Send feedback →';
        btn.disabled    = false;
        alert('Something went wrong: ' + (data.errors ? data.errors.map(e => e.message).join(', ') : 'please try again.'));
      });
    }
  })
  .catch(() => {
    btn.textContent = 'Send feedback →';
    btn.disabled    = false;
    alert('Network error — please check your connection and try again.');
  });
}

function showSuccess() {
  document.getElementById('feedback-form').style.display = 'none';
  const successEl = document.getElementById('form-success');
  successEl.style.display = 'block';
  successEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Mark first freq button active on load
window.addEventListener('load', () => {
  const first = document.querySelector('.freq-btn');
  if (first) first.classList.add('active');
});
</script>

